# Database
DATABASE_URL=postgresql+asyncpg://kitchen:kitchen@localhost:5432/kitchen

# LLM (OpenAI-compatible; default: 火山方舟 Ark)
OCR_PROVIDER=volcengine                  # volcengine | openai | mock
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# Leave LLM_API_KEY empty here; the app reads ARK_API_KEY_KITCHEN from shell env if LLM_API_KEY is unset.
LLM_API_KEY=
LLM_MODEL=doubao-seed-2-0-mini-260428
LLM_FORCE_JSON=true                      # true: response_format=json_object; false: prompt-only

# Mock (for local dev without API key)
OCR_MOCK_FIXTURE=

# Storage
STORAGE_DRIVER=local                     # local | s3
UPLOAD_DIR=./uploads

# Server
API_HOST=0.0.0.0
API_PORT=3000
WEB_ORIGIN=http://localhost:5173
