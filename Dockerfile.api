FROM python:3.13-slim

WORKDIR /app

# Install uv (per CLAUDE.md: not on PATH, use `python -m uv` or pip install)
RUN pip install --no-cache-dir uv

# First, install deps only (layer cache benefits: invalidated only when pyproject.toml/uv.lock change)
COPY apps/api/pyproject.toml apps/api/uv.lock ./
RUN uv sync --frozen --no-dev --no-install-project

# Then copy app code
COPY apps/api/app ./app
COPY apps/api/alembic ./alembic
COPY apps/api/alembic.ini ./

# Install the project itself (reuses cached deps)
RUN uv sync --frozen --no-dev

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

EXPOSE 3000

# Production: no --reload; 2 workers enough for family traffic
CMD ["uv", "run", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "3000", "--workers", "2"]
