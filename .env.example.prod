# === Database (must match compose env) ===
POSTGRES_USER=kitchen
POSTGRES_PASSWORD=<strong-random-password-here>
POSTGRES_DB=kitchen

# === LLM (Volcengine Ark) ===
LLM_API_KEY=ark-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL=doubao-seed-2-0-mini-260428
OCR_PROVIDER=volcengine
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_FORCE_JSON=true

# === Storage ===
STORAGE_DRIVER=local
UPLOAD_DIR=/app/uploads

# === CORS (same-origin in prod, but middleware still needs this) ===
WEB_ORIGIN=http://<ECS_PUBLIC_IP>
